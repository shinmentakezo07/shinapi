# Backend API (Go server)
BACKEND_URL=http://localhost:8080

# Database
# Options: postgres, neon, mongodb
DB_TYPE=postgres
# Local (docker-compose):
DATABASE_URL=postgresql://dra:dra_secret@localhost:5432/dra_platform
# Production (Neon):
# DATABASE_URL=postgresql://user:password@host:5432/database
MONGODB_URI=mongodb://localhost:27017
MONGODB_NAME=dra_platform

# NextAuth v5 (Auth.js) - REQUIRED for production
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-here
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# OAuth Providers (optional - for social login)
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# AI Provider (NVIDIA NIM / OpenAI compatible)
NVIDIA_API_KEY=nvapi-your-key-here
# Fallback / alternative
OPENAI_API_KEY=sk-your-key-here
