# Server
PORT=8080

# Database (same as frontend)
# Options: postgres, neon, mongodb
DB_TYPE=postgres
DATABASE_URL=postgresql://user:password@host:5432/database
MONGODB_URI=mongodb://localhost:27017
MONGODB_NAME=dra_platform

# Auth (must match frontend AUTH_SECRET)
AUTH_SECRET=your-auth-secret-here

# AI Providers
NVIDIA_API_KEY=nvapi-your-key-here
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here
GROQ_API_KEY=gsk-your-key-here
GEMINI_API_KEY=ai-your-key-here
YAPA_API_KEY=your-api-key-3
SHINWAY_API_KEY=your-shinway-api-key-here

# Default model alias (maps "default" to a real model)
MODEL_ALIASES=default:shinway/zl/zhipu/glm-5.1-full

# Environment
ENV=development
RATE_LIMIT_RPM=60
REQUEST_TIMEOUT=30s
SHUTDOWN_TIMEOUT=10s

# Cache
ENABLE_CACHE=true
CACHE_MAX_SIZE=10000
CACHE_DEFAULT_TTL=5m

# Observability
ENABLE_METRICS=true
METRICS_PORT=9090
